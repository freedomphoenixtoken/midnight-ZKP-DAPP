pragma language_version >=0.22;
import CompactStandardLibrary;

// Rental Trust Score ZK Proof
// Proves user's rental history without revealing specific transactions

export circuit verify_rental_trust(totalRentals: Uint<64>, successfulRentals: Uint<64>, onTimeReturns: Uint<64>): Boolean {
    const isValid = totalRentals >= 3 && successfulRentals >= 2 && onTimeReturns >= 2;
    return isValid;
}

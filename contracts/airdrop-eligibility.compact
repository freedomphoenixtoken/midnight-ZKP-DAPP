pragma language_version >=0.22;
import CompactStandardLibrary;

// Airdrop Eligibility ZK Proof
// Proves user eligibility for airdrop without revealing identity

export circuit verify_airdrop_eligibility(tokenHoldings: Uint<64>, minHoldings: Uint<64>, holdPeriod: Uint<64>): Boolean {
    const isValid = tokenHoldings >= minHoldings && holdPeriod >= 30;
    return isValid;
}
